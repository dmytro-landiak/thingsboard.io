---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { TRENDZ_RELEASE_FAMILIES, familySlug, patchSlug } from '~/models/trendz-releases-table';

export function getStaticPaths() {
	return TRENDZ_RELEASE_FAMILIES.map((f) => ({
		params: { familySlug: familySlug(f.family) },
		props: { family: f },
	}));
}

const { family: f } = Astro.props;
const slug = familySlug(f.family);

const title = `Trendz Analytics v${f.family}.x Release Notes`;

const headings = f.patches.map((p) => ({
	depth: 2,
	slug: patchSlug(p.version, p.date),
	text: `${p.version} (${p.date})`,
}));

const allNotes = import.meta.glob<{ default: any }>(
	'/src/content/_includes/docs/trendz/releases/*.mdx',
	{ eager: true },
);
const NotesComponent = allNotes[`/src/content/_includes/docs/trendz/releases/${slug}.mdx`]?.default;

const backUrl = '/docs/trendz/releases/releases-table/';
---

<StarlightPage frontmatter={{ title, tableOfContents: true }} {headings}>
	<p><a href={backUrl}>&larr; Back to all releases</a></p>
	{NotesComponent && <NotesComponent />}
</StarlightPage>
