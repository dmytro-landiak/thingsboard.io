---
import type { ImageMetadata } from 'astro';

interface Props {
	light: string | ImageMetadata;
	dark: string | ImageMetadata;
	alt: string;
	caption?: string;
	width?: string | number;
	height?: string | number;
	class?: string;
}

const { light, dark, alt, caption, width, height, class: className } = Astro.props;

const lightSrc = typeof light === 'string' ? light : light.src;
const darkSrc = typeof dark === 'string' ? dark : dark.src;
const captionText = caption || alt || '';
---

<themed-image class:list={['themed-image', className]}>
	<div class="themed-image__preview">
		<img class="light-only" src={lightSrc} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
		<img class="dark-only" src={darkSrc} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
		<button class="themed-image__expand" type="button" aria-label="View fullscreen">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<polyline points="15 3 21 3 21 9"></polyline>
				<polyline points="9 21 3 21 3 15"></polyline>
				<line x1="21" y1="3" x2="14" y2="10"></line>
				<line x1="3" y1="21" x2="10" y2="14"></line>
			</svg>
		</button>
	</div>

	<dialog class="themed-image__dialog">
		<button class="themed-image__close" type="button" aria-label="Close fullscreen">
			<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
		<div class="themed-image__dialog-body">
			<img class="light-only" src={lightSrc} alt={alt} loading="lazy" decoding="async" />
			<img class="dark-only" src={darkSrc} alt={alt} loading="lazy" decoding="async" />
		</div>
		{captionText && <p class="themed-image__caption">{captionText}</p>}
	</dialog>
</themed-image>

<script>
	class ThemedImageElement extends HTMLElement {
		constructor() {
			super();

			const expandBtn = this.querySelector('.themed-image__expand') as HTMLButtonElement;
			const dialog = this.querySelector('.themed-image__dialog') as HTMLDialogElement;
			const closeBtn = this.querySelector('.themed-image__close') as HTMLButtonElement;

			expandBtn.addEventListener('click', () => dialog.showModal());
			closeBtn.addEventListener('click', () => dialog.close());

			// Close when clicking anywhere on the dialog
			dialog.addEventListener('click', () => dialog.close());
		}
	}

	customElements.define('themed-image', ThemedImageElement);
</script>

<style lang="scss">
	@use '../styles/variables' as *;

	themed-image {
		display: block;
		margin: $spacing-6 0;
	}

	.themed-image__preview {
		position: relative;
		display: block;
	}

	.themed-image__preview img {
		max-width: 100%;
		height: auto;
	}

	/* Theme switching */
	.dark-only {
		display: none;
	}
	:global([data-theme='dark']) .light-only {
		display: none;
	}
	:global([data-theme='dark']) .dark-only {
		display: block;
	}

	/* Expand button */
	.themed-image__expand {
		position: absolute;
		top: $spacing-3;
		left: $spacing-3;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: none;
		border-radius: $radius-sm;
		background: rgba(0, 0, 0, 0.55);
		color: $color-white;
		cursor: pointer;
		opacity: 0;
		transition: opacity $transition-fast;

		&:hover {
			background: rgba(0, 0, 0, 0.75);
		}
	}

	.themed-image__preview:hover .themed-image__expand {
		opacity: 1;
	}

	/* Dialog — fills viewport, acts as its own backdrop */
	.themed-image__dialog {
		border: none;
		background: rgba(0, 0, 0, 0.8);
		max-width: none;
		max-height: none;
		width: 100vw;
		height: 100vh;
		margin: 0;
		padding: $spacing-10 $spacing-6 $spacing-8;
		position: fixed;
		inset: 0;
		cursor: pointer;
	}

	.themed-image__dialog[open] {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}

	.themed-image__dialog::backdrop {
		background: transparent;
	}

	.themed-image__close {
		position: fixed;
		top: $spacing-5;
		right: $spacing-5;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border: none;
		border-radius: $radius-sm;
		background: transparent;
		color: $color-white;
		cursor: pointer;
		transition: background $transition-fast;

		&:hover {
			background: rgba(255, 255, 255, 0.1);
		}
	}

	.themed-image__dialog-body {
		width: 90vw;
		height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: default;

		img {
			width: 100%;
			height: 100%;
			object-fit: contain;
		}
	}

	.themed-image__caption {
		margin-top: $spacing-6;
		color: rgba(255, 255, 255, 0.7);
		font-size: $font-size-sm;
		font-style: italic;
		text-align: center;
		cursor: default;
	}
</style>
