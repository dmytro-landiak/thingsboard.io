---
import DocLink from '@components/DocLink.astro';
import { Products } from '~/models/site.models';

interface Props {
	/** Current product context — banner only renders on CE pages */
	product: Products;
	/** Path to the corresponding documentation page (without leading/trailing slash).
	 *  Used to generate links to both PE and Cloud versions of this page.
	 *  When omitted, links point to the installation options pages. */
	path?: string;
}

const { product, path } = Astro.props;
const show = product === Products.CE;
const linkPath = path || 'installation';
---

{show && (
	<aside class="pe-feature-banner">
		<div class="pe-feature-banner-content">
			<p>
				This feature is available in <DocLink product={Products.PE} path={linkPath}>ThingsBoard Professional</DocLink> and <DocLink product={Products.PAAS} path={linkPath}>ThingsBoard Cloud</DocLink> only.
				<slot />
			</p>
		</div>
	</aside>
)}

<style>
	.pe-feature-banner {
		border: 1px solid var(--color-product-pe, #00695c);
		border-inline-start: 4px solid var(--color-product-pe, #00695c);
		border-radius: 0.5rem;
		padding: 0.75rem 1rem;
		margin-bottom: 1.5rem;
		background: color-mix(in srgb, var(--color-product-pe, #00695c) 6%, transparent);
	}

	.pe-feature-banner-content p {
		margin: 0;
		line-height: 1.6;
	}

	.pe-feature-banner a {
		color: var(--color-product-pe, #00695c);
		text-decoration: underline;
		text-decoration-color: color-mix(in srgb, var(--color-product-pe, #00695c) 40%, transparent);
		text-underline-offset: 2px;
	}

	.pe-feature-banner a:hover {
		text-decoration-color: var(--color-product-pe, #00695c);
	}
</style>
