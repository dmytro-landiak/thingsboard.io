---
import { Products, productDocsPrefix } from '~/models/site.models';

interface Props {
	product: Products;
	path: string;
	bold?: boolean;
	target?: '_blank' | '_self' | '_parent' | '_top';
	/**
	 * When true, variant products link to their canonical ThingsBoard docs instead
	 * of their own subtree — for pages that only live in the core CE/PE docs.
	 *   EDGE, TBMQ      → CE
	 *   EDGE_PE, TBMQ_PE → PE
	 */
	useTbDocs?: boolean;
}
const { product, path, bold = true, target, useTbDocs = false } = Astro.props;
const tbBase: Partial<Record<Products, Products>> = {
	[Products.EDGE]: Products.CE,
	[Products.EDGE_PE]: Products.PE,
	[Products.TBMQ]: Products.CE,
	[Products.TBMQ_PE]: Products.PE,
};
const effectiveProduct = useTbDocs ? (tbBase[product] ?? product) : product;
const [pathWithQuery, anchor] = path.split('#');
const [pathPart, query] = pathWithQuery.split('?');
const normalizedPath = pathPart === '' ? '' : (pathPart.endsWith('/') ? pathPart : pathPart + '/');
const href = `/docs/${productDocsPrefix[effectiveProduct]}${normalizedPath}${query ? '?' + query : ''}${anchor ? '#' + anchor : ''}`;
---

<a href={href} target={target} rel={target === '_blank' ? 'noopener noreferrer' : undefined}
	>{
		bold ? (
			<b><slot /></b>
		) : (
			<slot />
		)
	}</a
>
